{
  "manifest_version": 3,
  "name": "Tab Network Monitor",
  "version": "0.5.0",
  "description": "Shows live estimated network usage per browser tab.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "webRequest"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tab Network Monitor",
    "default_popup": "popup.html"
  }
}
