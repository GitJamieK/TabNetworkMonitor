{
  "manifest_version": 3,
  "name": "Tab Network Monitor",
  "version": "0.3.0",
  "description": "Shows live estimated network usage per browser tab.",
  "permissions": [
    "tabs",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tab Network Monitor",
    "default_popup": "popup.html"
  }
}
