{
  "manifest_version": 3,
  "name": "Tab Network Monitor",
  "version": "0.5.0",
  "description": "Shows live estimated network usage per browser tab.",
  "permissions": [
    "tabs",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "webRequestFilterResponse"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Tab Network Monitor",
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-network-monitor@jamiek.cc",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
